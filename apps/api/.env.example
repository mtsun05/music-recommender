# Express API port.
PORT=4000
# Clerk secret key from the Clerk dashboard; required for protected API routes.
CLERK_SECRET_KEY=
# Clerk publishable key, kept here for API-side Clerk configuration parity.
CLERK_PUBLISHABLE_KEY=
# Local Docker Postgres by default. Replace with a Supabase/Postgres connection string when using hosted DB.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/music_recommender
# Reserved for future Supabase client usage; direct Postgres access currently uses DATABASE_URL.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# LocalStack-compatible AWS defaults for local SQS.
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
SQS_RECOMMENDATION_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/recommendation-jobs
# Spotify OAuth account linking. Generate a 32-byte key with:
# openssl rand -base64 32
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:4000/spotify/callback
SPOTIFY_TOKEN_ENCRYPTION_KEY=
